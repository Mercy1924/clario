# Supabase Configuration
# Get these from: https://supabase.com/dashboard/project/_/settings/api
EXPO_PUBLIC_SUPABASE_URL=your-supabase-project-url
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# OAuth Configuration (set up in Supabase Dashboard > Authentication > Providers)
# Google: Enable in Supabase, then add client ID/secret from Google Cloud Console
# Apple: Enable in Supabase, then add services ID/key from Apple Developer

# OpenAI API Key (for AI analysis and diagram generation)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key
