{
  "expo": {
    "name": "Clarios",
    "slug": "clarios",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "clarios",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a1a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.clarios.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Clarios needs camera access to capture and analyse your spaces.",
        "NSMicrophoneUsageDescription": "Clarios needs microphone access for voice-guided sessions.",
        "NSPhotoLibraryUsageDescription": "Clarios saves session progress photos to your photo library."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#1a1a1a"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.clarios.app",
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "Clarios needs camera access to capture and analyse your spaces."
        }
      ],
      [
        "expo-speech",
        {
          "speechRecognitionPermission": "Clarios needs microphone access for voice-guided sessions."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
